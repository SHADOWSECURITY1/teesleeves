<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ page_title }}{% if page_title != shop.name %} | {{ shop.name }}{% endif %}</title>
  <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&family=Barlow+Condensed:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600&family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=Barlow:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&display=swap" rel="stylesheet">
  {{ 'theme.css' | asset_url | stylesheet_tag }}
  {{ content_for_header }}
</head>
<body>

  <!-- ANNOUNCE BAR -->
  <div class="announce-bar">&#9918; Veteran &amp; First Responder Owned &middot; 10% Off + Free Shipping &#9918;</div>

  <!-- NAV -->
  <nav>
    <a href="{{ routes.root_url }}" class="nav-logo" style="display:flex;align-items:center;gap:12px;text-decoration:none;">
      <img src="{{ 'logo.png' | asset_url }}" alt="{{ shop.name }}" style="height:48px;display:block">
      <span style="font-family:'Oswald',sans-serif;font-size:1.35rem;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:#f5f5f5;line-height:1;">TEE SLEEVES</span>
    </a>
    <div class="nav-links">
      <a href="/collections/all"{% if request.path contains '/collections' %} class="active"{% endif %}>Shop</a>
      <a href="/pages/teams-and-clubs"{% if request.path contains '/pages/teams-and-clubs' %} class="active"{% endif %}>Teams</a>
      <a href="/pages/about-us"{% if request.path contains '/pages/about-us' %} class="active"{% endif %}>About</a>
      <a href="/pages/contact"{% if request.path contains '/pages/contact' %} class="active"{% endif %}>Contact</a>
      <a href="/collections/all" class="nav-cta">Shop Now</a>
    </div>
  </nav>

  <main role="main" id="MainContent">
    {{ content_for_layout }}
  </main>

  <footer>
    <div class="footer-inner">
      <div class="footer-brand">
        <a href="{{ routes.root_url }}">
          <img src="{{ 'logo.png' | asset_url }}" alt="{{ shop.name }}" style="height:40px;display:block">
        </a>
        <p style="margin-top:10px;font-family:'Barlow Condensed',sans-serif;font-size:12px;letter-spacing:1.5px;text-transform:uppercase;color:var(--smoke);line-height:1.7;">
          Patent Pending &middot; Made in the USA<br>
          &copy; Tee Sleeves, LLC 2026
        </p>
      </div>
      <div class="footer-links">
        <a href="/collections/all">Shop</a>
        <a href="/pages/teams-and-clubs">Teams</a>
        <a href="/pages/about-us">About</a>
        <a href="/pages/contact">Contact</a>
      </div>
      <div class="footer-social">
        <a href="https://www.instagram.com/teesleeves_/" target="_blank" rel="noopener" aria-label="Instagram">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
        </a>
        <a href="https://www.facebook.com/teesleevesusa/" target="_blank" rel="noopener" aria-label="Facebook">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
        </a>
      </div>
    </div>
    <div class="footer-copy">&copy; {{ 'now' | date: "%Y" }} Tee Sleeves&trade; &middot; Protect Your Tee. Elevate Your Game. &middot; Made with &#10084; in the USA</div>
  </footer>

  <script>
  const observer = new IntersectionObserver(e => {
    e.forEach((entry, i) => {
      if (entry.isIntersecting) {
        setTimeout(() => entry.target.classList.add('visible'), i * 100);
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
  </script>

</body>
</html>
