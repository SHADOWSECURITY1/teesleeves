<!-- FAQ -->
<section class="faq-section">
  <div class="section-tag reveal">FAQ</div>
  <h2 class="section-title reveal">Common <span class="gold">Questions</span></h2>
  <div class="faq-list">
    <div class="faq-item reveal">
      <button class="faq-question">What size Tee Sleeve do I need? <span class="faq-toggle">+</span></button>
      <div class="faq-answer"><p>We offer three sizes: 2" fits standard slim tee stems (baseball &amp; softball), 3" fits baseball tees with a built-in ball retriever, and 4" fits softball tees with a ball hopper attachment. Check our size guide on the shop page if you're unsure.</p></div>
    </div>
    <div class="faq-item reveal">
      <button class="faq-question">What tees do Tee Sleeves fit? <span class="faq-toggle">+</span></button>
      <div class="faq-answer"><p>Tee Sleeves are designed to fit all major batting tee brands including Tanner, JUGS, G Tee, and more. The slip-on design accommodates variations in stem height and diameter across the three size options.</p></div>
    </div>
    <div class="faq-item reveal">
      <button class="faq-question">Do you offer custom team colors? <span class="faq-toggle">+</span></button>
      <div class="faq-answer"><p>Yes! For team orders of 10+, we can match any color. Send us a Pantone code, hex value, or even a photo of your team jersey and we'll match it. Visit our teams page to get started.</p></div>
    </div>
    <div class="faq-item reveal">
      <button class="faq-question">How long does shipping take? <span class="faq-toggle">+</span></button>
      <div class="faq-answer"><p>Standard orders ship within 1-2 business days and typically arrive in 3-5 business days. All orders ship free within the continental US. Custom team orders may take 1-2 additional weeks for production.</p></div>
    </div>
    <div class="faq-item reveal">
      <button class="faq-question">What is your return policy? <span class="faq-toggle">+</span></button>
      <div class="faq-answer"><p>We stand behind our product. If you're not completely satisfied, contact us within 30 days for a full refund or exchange. We want you to be happy with your Tee Sleeve.</p></div>
    </div>
    <div class="faq-item reveal">
      <button class="faq-question">Can I use Tee Sleeves as a team fundraiser? <span class="faq-toggle">+</span></button>
      <div class="faq-answer"><p>Absolutely! Many teams sell custom-branded Tee Sleeves as a fundraiser. Low cost, high margin, and parents actually want them. Contact us for fundraiser pricing and we'll help you set it up.</p></div>
    </div>
  </div>
</section>

<script>
// FAQ accordion
document.querySelectorAll('.faq-question').forEach(btn => {
  btn.addEventListener('click', () => {
    const item = btn.parentElement;
    const wasOpen = item.classList.contains('open');
    // Close all
    document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open'));
    // Toggle clicked
    if (!wasOpen) item.classList.add('open');
  });
});

// Scroll reveal
const observer = new IntersectionObserver(e => {
  e.forEach((e, i) => {
    e.isIntersecting && (setTimeout(() => e.target.classList.add('visible'), i * 100), observer.unobserve(e.target));
  });
}, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>