<div class="page-content reveal" style="max-width:860px;margin:60px auto;padding:0 24px">
  <h1 style="font-family:'Oswald',sans-serif;font-size:2.4rem;font-weight:700;text-transform:uppercase;letter-spacing:2px;color:var(--white);margin-bottom:32px;border-bottom:2px solid var(--crimson);padding-bottom:16px;">
    {{ page.title }}
  </h1>
  <div class="page-body" style="font-family:'Barlow',sans-serif;font-size:1.05rem;line-height:1.75;color:var(--light);">
    {{ page.content }}
  </div>
</div>
