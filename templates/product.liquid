{% assign current_variant = product.selected_or_first_available_variant %}

<div class="product-page">
  <div class="product-gallery reveal" style="background:radial-gradient(circle,#1a1a2a,#0e1117)">
    <div id="product-image-wrapper">
      {% if current_variant.image %}
        <img id="product-main-image"
             src="{{ current_variant.image | img_url: 'large' }}"
             alt="{{ current_variant.image.alt | default: product.title | escape }}"
             style="max-width:100%;height:auto;display:block">
      {% elsif product.featured_image %}
        <img id="product-main-image"
             src="{{ product.featured_image | img_url: 'large' }}"
             alt="{{ product.featured_image.alt | default: product.title | escape }}"
             style="max-width:100%;height:auto;display:block">
      {% endif %}
    </div>
  </div>

  <div class="product-details reveal">
    <div class="product-breadcrumb">
      <a href="/collections/all">Shop</a> &nbsp;/&nbsp; {{ product.title }}
    </div>

    <h1 class="product-name">{{ product.title }}</h1>

    <div class="product-price-row">
      <div class="product-price" id="product-price">
        {{ current_variant.price | money }}
      </div>
      <div class="product-shipping">&#10003; Free Shipping</div>
    </div>

    <p class="product-desc">{{ product.description }}</p>

    {% form 'product', product, id: 'product-form' %}
      <input type="hidden" name="id" value="{{ current_variant.id }}" id="variant-id">

      {% for option in product.options_with_values %}

        {%- assign option_name_down = option.name | downcase -%}

        {% if option_name_down == 'size' %}
          <div class="product-option-label">Size</div>
          <div class="size-options">
            {% for value in option.values %}
              <div class="size-opt{% if option.selected_value == value %} selected{% endif %}"
                   data-option-index="{{ option.position }}"
                   data-option-value="{{ value | escape }}">
                {{ value }}
              </div>
            {% endfor %}
          </div>
          <div class="size-desc" id="sizeDesc">
            {%- if current_variant.title contains '2"' -%}
              Universal pure slip cover. No ball retriever. Fits standard slim tee stems for baseball or softball.
            {%- elsif current_variant.title contains '3"' -%}
              Includes baseball hopper attachment. Picks up baseballs after each swing. Built for baseball tees.
            {%- elsif current_variant.title contains '4"' -%}
              Includes softball hopper attachment. Sized for softballs. Compatible with most softball tee bases.
            {%- else -%}
              Select a size to see details.
            {%- endif -%}
          </div>

        {% elsif option_name_down == 'color' %}
          <div class="product-option-label">Color</div>
          <div class="color-options">
            {% for value in option.values %}
              {%- assign color_class = value | downcase | replace: ' ', '-' -%}
              <label class="color-opt co-{{ color_class }}{% if option.selected_value == value %} selected{% endif %}"
                     title="{{ value }}"
                     data-option-index="{{ option.position }}"
                     data-option-value="{{ value | escape }}">
                <input type="radio"
                       name="options[{{ option.name | escape }}]"
                       value="{{ value | escape }}"
                       {% if option.selected_value == value %}checked{% endif %}
                       style="display:none">
              </label>
            {% endfor %}
          </div>

        {% elsif option_name_down == 'logo' %}
          <div class="product-option-label">Custom Logo Sticker
            <span style="font-size:0.8em;color:var(--gold);font-weight:400;margin-left:8px;">+$9.95 if added</span>
          </div>
          <div class="logo-options" style="display:flex;gap:12px;margin-bottom:16px;">
            {% for value in option.values %}
              <div class="size-opt logo-opt{% if option.selected_value == value %} selected{% endif %}"
                   data-option-index="{{ option.position }}"
                   data-option-value="{{ value | escape }}"
                   style="flex:1;text-align:center;">
                {{ value }}
              </div>
            {% endfor %}
          </div>

        {% endif %}
      {% endfor %}

      <button type="submit" name="add" class="add-to-cart" id="add-to-cart"
              {% unless current_variant.available %}disabled{% endunless %}>
        {% if current_variant.available %}
          Add to Cart
        {% else %}
          Sold Out
        {% endif %}
      </button>

    {% endform %}

    <a href="/pages/teams-and-clubs" class="btn-ghost" style="width:100%;justify-content:center;margin-top:12px;">
      Ordering for a Team? Get 20% Off
    </a>

    <div class="product-features">
      <div class="pf-item">&#9728;&#65039; UV Resistant</div>
      <div class="pf-item">&#128167; Weatherproof</div>
      <div class="pf-item">&#127482;&#127480; Made in USA</div>
      <div class="pf-item">&#127912; Custom Branding</div>
    </div>
  </div>
</div>

<script>
var productVariants = {{ product.variants | json }};

var sizeDescriptions = {
  '2"':                      'Universal pure slip cover. No ball retriever. Fits standard slim tee stems for baseball or softball.',
  '3" with Baseball Hopper': 'Includes baseball hopper attachment. Picks up baseballs after each swing. Built for baseball tees.',
  '4" with Softball Hopper': 'Includes softball hopper attachment. Sized for softballs. Compatible with most softball tee bases.'
};

// Click handler for size-opt and color-opt labels
document.querySelectorAll('.size-opt, .color-opt, .logo-opt').forEach(function(el) {
  el.addEventListener('click', function() {
    // Deselect siblings in same option group
    var idx = this.dataset.optionIndex;
    document.querySelectorAll('[data-option-index="' + idx + '"]').forEach(function(s) {
      s.classList.remove('selected');
    });
    this.classList.add('selected');

    // Check any hidden radio inside (for color swatches)
    var radio = this.querySelector('input[type="radio"]');
    if (radio) radio.checked = true;

    updateVariant();
  });
});

function updateVariant() {
  // Gather one selected value per option index
  var selectedOptions = {};
  document.querySelectorAll('[data-option-index].selected').forEach(function(el) {
    selectedOptions[el.dataset.optionIndex] = el.dataset.optionValue;
  });

  var selectedArr = [];
  Object.keys(selectedOptions).sort().forEach(function(k) {
    selectedArr.push(selectedOptions[k]);
  });

  // Find matching variant
  var match = productVariants.find(function(v) {
    return v.options.every(function(o, i) {
      return !selectedArr[i] || o === selectedArr[i];
    });
  });

  if (match) {
    document.getElementById('variant-id').value = match.id;

    // Update price
    var price = '$' + (match.price / 100).toFixed(2);
    document.getElementById('product-price').textContent = price;

    // Update button
    var btn = document.getElementById('add-to-cart');
    btn.textContent = match.available ? 'Add to Cart' : 'Sold Out';
    btn.disabled = !match.available;

    // Update size description
    var sizeEl = document.getElementById('sizeDesc');
    if (sizeEl && selectedOptions['1']) {
      var desc = sizeDescriptions[selectedOptions['1']];
      if (desc) sizeEl.textContent = desc;
    }

    // Update image if variant has one
    var imgEl = document.getElementById('product-main-image');
    if (imgEl && match.featured_image) {
      imgEl.src = match.featured_image.src;
    }
  }
}
</script>
