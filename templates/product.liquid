{% assign current_variant = product.selected_or_first_available_variant %}

{% assign card_accent = '#333' %}
{% assign card_bg = 'radial-gradient(circle,#1a1a2a,#0e1117)' %}
{% if product.title contains 'Red' or product.title contains 'Crimson' %}
  {% assign card_accent = '#c41e3a' %}
  {% assign card_bg = 'radial-gradient(circle,#2a0a15,#0e1117)' %}
{% elsif product.title contains 'Navy' or product.title contains 'Blue' %}
  {% assign card_accent = '#1a3a5c' %}
  {% assign card_bg = 'radial-gradient(circle,#0a1530,#0e1117)' %}
{% elsif product.title contains 'White' %}
  {% assign card_accent = '#888' %}
  {% assign card_bg = 'radial-gradient(circle,#1f2030,#0e1117)' %}
{% endif %}

{% assign color_name = product.title | remove: 'Tee Sleeves™ – ' | remove: 'Tee Sleeves - ' | remove: 'Tee Sleeves™ - ' | remove: 'Tee Sleeves ' %}

<div class="product-page">

  <!-- ══ BASEBALL CARD IMAGE PANEL ══ -->
  <div class="product-gallery reveal" style="background:transparent;padding:40px 20px;">
    <div class="bcard-inner" style="--card-accent:{{ card_accent }};max-width:380px;margin:0 auto;cursor:default;">
      <div class="bcard-frame" style="background:{{ card_bg }};">
        <div class="bcard-badge" style="background:#d4a853;color:#1a1a1a;">Tee Sleeves&trade;</div>
        {% if product.featured_image %}
          <img id="product-main-image"
               src="{{ product.featured_image | img_url: 'large' }}"
               alt="{{ product.featured_image.alt | default: product.title | escape }}"
               style="width:100%;display:block;">
        {% endif %}
        <div class="bcard-banner">
          <div class="bcard-team">Tee Sleeves&trade;</div>
          <div class="bcard-name">{{ color_name }}</div>
        </div>
      </div>
      <div class="bcard-info" style="padding:16px 20px 20px;">
        <div class="bcard-stats">
          <div class="bcard-stat"><div class="bcard-stat-val">&#9728;&#65039;</div><div class="bcard-stat-label">UV Block</div></div>
          <div class="bcard-stat"><div class="bcard-stat-val">&#128167;</div><div class="bcard-stat-label">Rain Guard</div></div>
          <div class="bcard-stat"><div class="bcard-stat-val">&#127482;&#127480;</div><div class="bcard-stat-label">USA Made</div></div>
          <div class="bcard-stat"><div class="bcard-stat-val">&#128081;</div><div class="bcard-stat-label">Patent Pend.</div></div>
        </div>
      </div>
    </div>

    <!-- Color switcher links -->
    <div style="display:flex;gap:12px;justify-content:center;margin-top:20px;">
      <a href="/products/tee-sleeves%E2%84%A2-black"  title="Stealth Black"  style="width:28px;height:28px;border-radius:50%;background:#1a1a1a;border:2px solid {% if product.handle contains 'black' %}#d4a853{% else %}#444{% endif %};display:block;"></a>
      <a href="/products/tee-sleeves%E2%84%A2-red"    title="Crimson Red"    style="width:28px;height:28px;border-radius:50%;background:#c41e3a;border:2px solid {% if product.handle contains 'red' %}#d4a853{% else %}#444{% endif %};display:block;"></a>
      <a href="/products/tee-sleeve"                  title="Navy Blue"      style="width:28px;height:28px;border-radius:50%;background:#1a3a5c;border:2px solid {% if product.handle == 'tee-sleeve' %}#d4a853{% else %}#444{% endif %};display:block;"></a>
      <a href="/products/tee-sleeves%E2%84%A2-white"  title="Clean White"    style="width:28px;height:28px;border-radius:50%;background:#e0e0e0;border:2px solid {% if product.handle contains 'white' %}#d4a853{% else %}#444{% endif %};display:block;"></a>
    </div>
  </div>

  <!-- ══ PRODUCT DETAILS ══ -->
  <div class="product-details reveal">
    <div class="product-breadcrumb">
      <a href="/collections/all">Shop</a> &nbsp;/&nbsp; {{ product.title }}
    </div>

    <h1 class="product-name">{{ product.title }}</h1>

    <div class="product-price-row">
      <div class="product-price">
        <span style="font-size:0.55em;font-weight:400;opacity:0.7;display:block;letter-spacing:1px;text-transform:uppercase;margin-bottom:2px;">Starting at</span>
        $<span id="displayed-price">34.95</span>
      </div>
      <div class="product-shipping">&#10003; Free Shipping</div>
    </div>

    <!-- ── SIZE SELECTOR ── -->
    <div class="product-option-label">Size</div>
    <div class="size-options" id="size-options">
      <div class="size-opt selected" data-size='2"' data-base="34.95" onclick="selectSize(this)">2"</div>
      <div class="size-opt" data-size='3" + Baseball Hopper' data-base="49.95" onclick="selectSize(this)">3" + Baseball Hopper</div>
      <div class="size-opt" data-size='4" + Softball Hopper' data-base="49.95" onclick="selectSize(this)">4" + Softball Hopper</div>
    </div>
    <div class="size-desc" id="sizeDesc">Universal pure slip cover. No ball retriever. Fits standard slim tee stems for baseball or softball.</div>

    <!-- ── LOGO UPGRADE ── -->
    <div class="product-option-label" style="margin-top:20px;">
      Custom Logo Sticker
      <span style="font-size:0.75em;color:var(--gold);font-weight:400;margin-left:8px;">+$9.95</span>
    </div>
    <div style="display:flex;gap:10px;margin-bottom:20px;">
      <div class="size-opt selected" id="logo-no"  onclick="selectLogo(this,'no')"  style="flex:1;text-align:center;">No Logo</div>
      <div class="size-opt"          id="logo-yes" onclick="selectLogo(this,'yes')" style="flex:1;text-align:center;">&#127912; Add Custom Logo +$9.95</div>
    </div>

    <p class="product-desc">{{ product.description }}</p>

    {% form 'product', product, id: 'product-form' %}
      <input type="hidden" name="id"                       value="{{ current_variant.id }}">
      <input type="hidden" name="properties[Size]"         id="prop-size"  value='2"'>
      <input type="hidden" name="properties[Custom Logo]"  id="prop-logo"  value="No Logo">

      <button type="submit" name="add" class="add-to-cart" id="add-to-cart">
        Add to Cart — $<span id="btn-price">34.95</span>
      </button>
    {% endform %}

    <a href="/pages/teams-and-clubs" class="btn-ghost" style="width:100%;justify-content:center;margin-top:12px;">
      Ordering for a Team? Get 20% Off &rarr;
    </a>

    <div class="product-features" style="margin-top:24px;">
      <div class="pf-item">&#9728;&#65039; UV Resistant</div>
      <div class="pf-item">&#128167; Weatherproof</div>
      <div class="pf-item">&#127482;&#127480; Made in USA</div>
      <div class="pf-item">&#127912; Custom Branding</div>
    </div>
  </div>
</div>

<script>
var sizeDescriptions = {
  '2"':                      'Universal pure slip cover. No ball retriever. Fits standard slim tee stems for baseball or softball.',
  '3" + Baseball Hopper':    'Includes baseball hopper attachment. Picks up baseballs after each swing. Built for baseball tees.',
  '4" + Softball Hopper':    'Includes softball hopper attachment. Sized for softballs. Compatible with most softball tee bases.'
};

var currentBase  = 34.95;
var logoUpcharge = 0;

function selectSize(el) {
  document.querySelectorAll('#size-options .size-opt').forEach(function(s) { s.classList.remove('selected'); });
  el.classList.add('selected');
  currentBase = parseFloat(el.dataset.base);
  document.getElementById('prop-size').value = el.dataset.size;
  var desc = sizeDescriptions[el.dataset.size];
  if (desc) document.getElementById('sizeDesc').textContent = desc;
  updatePrice();
}

function selectLogo(el, choice) {
  document.getElementById('logo-no').classList.remove('selected');
  document.getElementById('logo-yes').classList.remove('selected');
  el.classList.add('selected');
  logoUpcharge = (choice === 'yes') ? 9.95 : 0;
  document.getElementById('prop-logo').value = (choice === 'yes') ? 'Add Custom Logo (+$9.95)' : 'No Logo';
  updatePrice();
}

function updatePrice() {
  var total = (currentBase + logoUpcharge).toFixed(2);
  document.getElementById('displayed-price').textContent = total;
  document.getElementById('btn-price').textContent = total;
}
</script>
